# ── LOCAL (Docker postgres) ────────────────────────────────────────────────────
# Usar variables individuales para evitar SSL forzado en Docker local.
# Copiar este bloque a backend/.env para desarrollo local.
PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=erm_user
DB_PASSWORD=erm_password
DB_NAME=erm_intelligence

# ── PRODUCCIÓN (cualquier plataforma cloud) ────────────────────────────────────
# Solo necesitas DATABASE_URL. Las variables DB_* son ignoradas cuando existe DATABASE_URL.
# Render:   se inyecta automáticamente al vincular un Postgres service
# Railway:  ${{Postgres.DATABASE_URL}}
# Fly.io:   fly secrets set DATABASE_URL=postgresql://...
#
# PORT=3000
# DATABASE_URL=postgresql://user:password@host:5432/dbname

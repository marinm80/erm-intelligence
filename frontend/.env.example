# ── LOCAL ──────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ── PRODUCCIÓN ─────────────────────────────────────────────────────────────────
# VITE_API_URL se incrusta en el bundle de JS en tiempo de build (no en runtime).
# Debe estar configurado en la plataforma ANTES de ejecutar npm run build.
# Render:   Environment settings del servicio (static site)
# Railway:  Variables del servicio
# Fly.io:   [env] en fly.toml o fly secrets
#
# VITE_API_URL=https://tu-backend.onrender.com
